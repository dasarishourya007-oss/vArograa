rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /doctors/{doctorId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == doctorId;
    }

    match /hospitals/{hospitalId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == hospitalId;
    }

    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
