rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isDemoId(id) {
      return id.indexOf("demo-") == 0;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Global Demo Access: Allow read/write for any document ID starting with "demo-"
    // This supports the unauthenticated migration script and demo dashboard bypasses.
    match /{collection}/{id} {
      allow read, write: if isDemoId(id);
    }

    // USERS
    match /users/{userId} {
      allow read: if true; // Required for role check in the app
      allow write: if isDemoId(userId) || isOwner(userId);
    }

    // PATIENTS
    match /patients/{patientId} {
      allow read: if true;
      allow write: if isDemoId(patientId) || isOwner(patientId);
    }

    // HOSPITALS & DOCTORS
    match /hospitals/{hospitalId} {
      allow read: if true;
      allow write: if isDemoId(hospitalId) || isOwner(hospitalId);
    }
    match /doctors/{doctorId} {
      allow read: if true;
      allow write: if isDemoId(doctorId) || isOwner(doctorId);
    }

    // MEDICAL STORES
    match /medical_stores/{storeId} {
      allow read: if true;
      allow write: if isDemoId(storeId) || isOwner(storeId);
    }
    match /medicalStores/{storeId} {
      allow read, write: if true; 
    }

    // TRANSACTIONAL COLLECTIONS
    // Allow read if signed in OR if it's a demo document.
    // Allow create if it's a demo document.
    
    match /appointments/{id} { allow read, write: if true; }
    match /vitals/{id} { allow read, write: if true; }
    match /sos_requests/{id} { allow read, write: if true; }
    match /ai_triage_logs/{id} { allow read, write: if true; }
    match /medicine_orders/{id} { allow read, write: if true; }
    match /notifications/{id} { allow read, write: if true; }
    match /medical_records/{id} { allow read, write: if true; }
    match /prescriptions/{id} { allow read, write: if true; }

    // Subcollections support
    match /{path=**} {
      allow read, write: if request.auth != null || path[path.size()-1].indexOf("demo-") == 0;
    }
  }
}